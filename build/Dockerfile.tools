FROM python:3.12-slim-bookworm

RUN pip install --no-cache-dir \
    grpcio-tools>=1.68.0 \
    mypy-protobuf>=3.6 \
    mypy>=1.14 \
    ruff>=0.8 \
    pytest>=8.3 \
    pytest-cov>=6.0 \
    pytest-asyncio>=0.24 \
    grpcio>=1.68.0 \
    protobuf>=5.29.0 \
    googleapis-common-protos>=1.66.0 \
    build

WORKDIR /workspace
